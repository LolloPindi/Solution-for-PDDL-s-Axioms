#!/usr/bin/env bash
# dntp_run - interfaccia per il sistema DNTP (FD + bridge ASP/Clingo)
set -uo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FD="$HERE/FastDownward"
DOM="$HERE/ASP/dntp/domain_dntp.pddl"
INSTDIR="$HERE/FULLDOMAIN+INSTANCES/06_domain_RAD_RESTORE_primary_edge"
ENCDIR="$HERE/ASP/dntp"
PLANS="$HERE/Plans"
TIMEOUT=600
# --- carica config.env (percorsi Clingo) ---
if [ -f "$HERE/config.env" ]; then
  set -a; . "$HERE/config.env"; set +a
fi
if [ -z "${CLINGO_LIB:-}" ] || ! ls "${CLINGO_LIB}"/libclingo.so* >/dev/null 2>&1; then
  echo "ERRORE: CLINGO_LIB non valido (manca libclingo.so in '${CLINGO_LIB:-<vuoto>}')."
  echo "  Modifica $HERE/config.env impostando CLINGO_LIB al percorso della lib di Clingo."
  exit 1
fi
export LD_LIBRARY_PATH="$CLINGO_LIB:${LD_LIBRARY_PATH:-}"
mkdir -p "$PLANS"


search_config () {
  case "$1" in
    ff|greedy|gready)   echo "lazy_greedy([ff()])" ;;
    eager_ff)           echo "eager_greedy([ff()])" ;;
    astar|Astar|a*)     echo "astar(blind())" ;;
    astar_ff)           echo "astar(ff())" ;;
    wastar)             echo "eager(single(weighted_eval([ff()],2)))" ;;
    blind)              echo "eager(single(blind()))" ;;
    *) echo "" ;;
  esac
}


enc_file () {
  case "$1" in
    full|"")     echo "$ENCDIR/full.lp" ;;
    rad)         echo "$ENCDIR/rad.lp" ;;
    rest_p)      echo "$ENCDIR/rest_p.lp" ;;
    rest_e)      echo "$ENCDIR/rest_e.lp" ;;
    rad_rest_p)  echo "$ENCDIR/rad_rest_p.lp" ;;
    *)           echo "$1" ;;   # path esplicito
  esac
}

usage () {
cat <<USAGE
dntp_run - esegue il planner DNTP con assiomi valutati via ASP

USO:
  dntp_run --real -all            esegue tutte le istanze reali (P06..P150)
  dntp_run --real P13             esegue una reale
  dntp_run --N -all               esegue tutte le sintetiche (N_*)
  dntp_run --N N_8                esegue le sintetiche di una taglia
  dntp_run --N <nome_completo>    esegue una sintetica specifica
  dntp_run -l                     lista tutte le istanze
  dntp_run -l --real | -l --N     lista solo reali / sintetiche
  dntp_run -h                     questo aiuto

OPZIONI:
  --enc <nome>     encoding ASP: full(default), rad, rest_p, rest_e, rad_rest_p, o path .lp
  --search <nome>  ricerca: ff(default), eager_ff, astar, astar_ff, wastar, blind
  --to <sec>       timeout per istanza (default $TIMEOUT)

I piani trovati sono salvati in: $PLANS/
USAGE
}

# --- parsing ---
SET=""; TARGET=""; ENCN="full"; SEARCHN="ff"; LIST=0
ARGS=("$@")
i=0
while [ $i -lt ${#ARGS[@]} ]; do
  a="${ARGS[$i]}"
  case "$a" in
    -h|--help) usage; exit 0 ;;
    -l|--list) LIST=1 ;;
    --real)    SET="real" ;;
    --N)       SET="N" ;;
    --enc)     i=$((i+1)); ENCN="${ARGS[$i]}" ;;
    --search)  i=$((i+1)); SEARCHN="${ARGS[$i]}" ;;
    --to)      i=$((i+1)); TIMEOUT="${ARGS[$i]}" ;;
    -all|--all) TARGET="-all" ;;
    *)         TARGET="$a" ;;
  esac
  i=$((i+1))
done

# --- lista istanze ---
if [ $LIST -eq 1 ]; then
  if [ "$SET" != "N" ]; then echo ""; ls "$INSTDIR"/P*.pddl 2>/dev/null | xargs -n1 basename | sed 's/.pddl//' | sort -V; fi
  if [ "$SET" != "real" ]; then echo ""; ls "$INSTDIR"/N_*.pddl 2>/dev/null | xargs -n1 basename | sed 's/.pddl//'; fi
  exit 0
fi

[ -z "$SET" ] && { echo "ERRORE: specifica --real o --N (o -l per la lista, -h per aiuto)"; exit 1; }
ENC="$(enc_file "$ENCN")"
[ -f "$ENC" ] || { echo "ERRORE: encoding non trovato: $ENC"; exit 1; }
SEARCH="$(search_config "$SEARCHN")"
[ -z "$SEARCH" ] && { echo "ERRORE: ricerca sconosciuta '$SEARCHN' (ff|eager_ff|astar|astar_ff|wastar|blind)"; exit 1; }

# --- raccogli la lista di file da eseguire ---
FILES=()
if [ "$SET" = "real" ]; then
  if [ "$TARGET" = "-all" ] || [ -z "$TARGET" ]; then
    while IFS= read -r f; do FILES+=("$f"); done < <(ls "$INSTDIR"/P*.pddl | sort -V)
  else
    t="$TARGET"; [[ "$t" == *.pddl ]] || t="$INSTDIR/$t.pddl"
    FILES+=("$t")
  fi
else
  if [ "$TARGET" = "-all" ] || [ -z "$TARGET" ]; then
    while IFS= read -r f; do FILES+=("$f"); done < <(ls "$INSTDIR"/N_*.pddl | sort)
  else
    # prefisso (N_8) o nome completo
    matches=("$INSTDIR/$TARGET"*.pddl)
    if [ -e "${matches[0]}" ]; then for f in "${matches[@]}"; do FILES+=("$f"); done
    else t="$TARGET"; [[ "$t" == *.pddl ]] || t="$INSTDIR/$t.pddl"; FILES+=("$t"); fi
  fi
fi

# --- CSV ---
STAMP="$(date +%Y%m%d_%H%M%S)"
CSV="$PLANS/results_${SET}_${ENCN}_${SEARCHN}_${STAMP}.csv"
echo "istanza,N,alpha,piano,espansi,valutati,tempo_s,esito" > "$CSV"

echo "encoding: $ENC"
echo "ricerca : $SEARCH  ($SEARCHN)"
echo "timeout : ${TIMEOUT}s   |   piani in: $PLANS"
echo
printf "%-50s | %-5s | %-9s | %-8s | %s\n" "istanza" "piano" "valutati" "tempo" "esito"
printf -- "---------------------------------------------------+-------+-----------+----------+--------\n"

gen_facts () {
python3 - "$1" 2>/dev/null << 'PY'
import json, re, sys
d=json.load(open(sys.argv[1])); V,TYPE,E=d['V'],d['TYPE'],d['E']
BUILD=set(d.get('BUILDABLE',[])); REMOV=set(d.get('REMOVABLE',[]))
M=d.get('MUTABLE',{}); MUT=set(M.keys() if isinstance(M,dict) else M); dyn=BUILD|REMOV|MUT
low=lambda n:n.lower(); idx=lambda n:int(re.sub(r'\D','',n) or 0); sec=lambda n:str(TYPE[n]).upper().startswith('S')
order=sorted([n for n in V if sec(n)],key=idx)+sorted([n for n in V if not sec(n)],key=idx)
def canon(a,b):
    ra=(0 if sec(a) else 1,idx(a)); rb=(0 if sec(b) else 1,idx(b)); return (a,b) if ra<rb else (b,a)
sc=[]
for e in E:
    a,b=e.split('-')
    if e in dyn: continue
    x,y=canon(a,b); sc.append(f"conn({low(x)},{low(y)}).")
o=[]; o.append(" ".join(f"node({low(n)})." for n in order))
o.append(" ".join(f"secondary({low(n)})." for n in order if sec(n)))
o.append(" ".join(f"primary({low(n)})." for n in order if not sec(n)))
le=[f"le({low(order[i])},{low(order[j])})." for i in range(len(order)) for j in range(i+1,len(order))]
for k in range(0,len(le),8): o.append(" ".join(le[k:k+8]))
o.append(" ".join(sc)); print("\n".join(o))
PY
}

for pddl in "${FILES[@]}"; do
  name="$(basename "$pddl" .pddl)"
  json="${pddl%.pddl}.json"
  N="$(echo "$name" | grep -oE 'N_[0-9]+' | grep -oE '[0-9]+'); N=${N:-}"
  AL="$(echo "$name" | grep -oE 'alpha_[0-9.]+' | grep -oE '[0-9.]+'); AL=${AL:-}"
  if [ ! -f "$pddl" ] || [ ! -f "$json" ]; then
    printf "%-50s | %-5s | %-9s | %-8s | %s\n" "$name" "-" "-" "-" "MANCANTE"
    echo "$name,$N,$AL,-,-,-,-,MANCANTE" >> "$CSV"; continue
  fi
  tmp="$(mktemp /tmp/dntp_XXXX.facts)"
  gen_facts "$json" > "$tmp"
  export DNTP_EVAL="$ENC" DNTP_FACTS="$tmp"
  ( cd "$FD" && rm -f sas_plan && timeout "$TIMEOUT" ./fast-downward.py "$DOM" "$pddl" --search "$SEARCH" >/tmp/dntp_run.log 2>&1 )
  rc=$?
  if grep -q "Solution found" /tmp/dntp_run.log; then
    pl=$(grep -c '^(' "$FD/sas_plan")
    tm=$(grep -oE "Total time: [0-9.]+s" /tmp/dntp_run.log|tail -1|grep -oE "[0-9.]+")
    ex=$(grep -oE "Expanded [0-9]+ state" /tmp/dntp_run.log|tail -1|grep -oE "[0-9]+")
    ev=$(grep -oE "Evaluated [0-9]+ state" /tmp/dntp_run.log|tail -1|grep -oE "[0-9]+")
    cp "$FD/sas_plan" "$PLANS/${name}.plan"
    printf "%-50s | %-5s | %-9s | %-8s | %s\n" "$name" "$pl" "$ev" "$tm" "OK"
    echo "$name,$N,$AL,$pl,$ex,$ev,$tm,OK" >> "$CSV"
  else
    if [ $rc -eq 124 ]; then es="TIMEOUT"; else es="NO-SOL/ERR"; fi
    printf "%-50s | %-5s | %-9s | %-8s | %s\n" "$name" "-" "-" "-" "$es"
    echo "$name,$N,$AL,-,-,-,-,$es" >> "$CSV"
  fi
  rm -f "$tmp"
done

echo
echo "CSV salvato: $CSV"
echo "Piani salvati in: $PLANS/"
